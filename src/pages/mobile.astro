---
import InstallerLayout from '../layouts/InstallerLayout.astro';
import CommandFooter from '../components/CommandFooter.astro';
import PackageControls from '../components/PackageControls.astro';
---
<InstallerLayout
  title="Mobile Installer"
  heading="Mobile Installer"
  navBack={{ href: '/', label: 'Back to Home' }}
  navCompat={{ href: '/mobile-os-compatibility', label: 'Go Mobile Packages Table' }}
>
  <section class="package-section">
    <form id="packageForm">
      <div class="container">
        <div class="os-selector-container">
          <div class="primary-os-selector">
            <button type="button" class="os-btn" data-os="android">🔥 Android</button>
            <button type="button" class="os-btn" data-os="ios">🐧 iOS</button>
          </div>
        </div>
        <PackageControls searchPlaceholder="Search packages by name">
          <select id="optionsSelect" class="options-select">
            <option value="" hidden selected>⚙️ Options</option>
            <option value="loadFavorites">✨ My Favorites</option>
            <option value="importPackages">📥 Import packages (JSON)</option>
            <option value="exportPackages">📤 Export packages (JSON)</option>
          </select>
        </PackageControls>
      </div>
      <div id="packageContainer" class="package-container columns"></div>
    </form>
  </section>
  <CommandFooter />
  <script>
    import '../scripts/app';
  </script>
</InstallerLayout>
