---
import CompatLayout from '../layouts/CompatLayout.astro';
---
<CompatLayout
  title="VS Code Extensions Table"
  heading="🧩 VS Code Extensions Compatibility"
  subtitle="Installed extension list and package identifiers for command generation."
  installerHref="vscode"
  installerLabel="Go to Installer"
  searchPlaceholder="Search extension name, package name, or category"
>
  <div slot="controls" class="page-controls-panel">
    <div class="page-filter-row filter-chips" id="filterChips" role="group" aria-label="Filter by extension category"></div>
  </div>
  <p class="page-note">Search, sort, and filter extensions by category with the same software-table pattern used on desktop.</p>
  <div class="table-container">
    <table id="packagesTable">
      <thead id="tableHead"></thead>
      <tbody id="tableBody"></tbody>
    </table>
  </div>
  <div class="stats" id="statsContainer"></div>
  <script slot="script">
    import '/src/scripts/software-table-pages';
  </script>
</CompatLayout>
