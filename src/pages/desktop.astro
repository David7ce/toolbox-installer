---
import InstallerLayout from '../layouts/InstallerLayout.astro';
import CommandFooter from '../components/CommandFooter.astro';
---
<InstallerLayout
  title="Desktop Installer"
  heading="Desktop Installer"
  navBack={{ href: '/', label: 'Back to Home' }}
  navCompat={{ href: '/desktop-os-compatibility', label: 'Go Desktop Packages Table' }}
>
  <section class="package-section">
    <form id="packageForm">
      <div class="container">
        <div class="os-selector-container">
          <div class="primary-os-selector">
            <button type="button" class="os-btn active" data-os="windows">🪟 Windows</button>
            <button type="button" class="os-btn" data-os="macos">🍎 macOS</button>
            <button type="button" class="os-btn" data-os="linux">🐧 Linux</button>
            <button type="button" class="os-btn" data-os="freebsd">🔥 FreeBSD</button>
          </div>
          <div class="secondary-os-selector hidden" id="linuxDistroSelector">
            <button type="button" class="distro-btn active" data-distro="linux_arch_pacman">Arch (pm+yay)</button>
            <button type="button" class="distro-btn" data-distro="linux_debian_apt">Debian (apt)</button>
            <button type="button" class="distro-btn" data-distro="linux_fedora_rpm">Fedora (rpm)</button>
            <button type="button" class="distro-btn" data-distro="linux_gentoo_emerge">Gentoo (emerge)</button>
            <button type="button" class="distro-btn" data-distro="linux_flatpak">Linux (flatpak)</button>
            <button type="button" class="distro-btn" data-distro="unix_nix_env">Linux (nix)</button>
            <button type="button" class="distro-btn" data-distro="linux_snap">Linux (snap)</button>
          </div>
        </div>
        <div class="page-controls">
          <div class="page-controls-panel main-controls">
            <input id="searchInput" class="search-input" type="search" placeholder="Search packages by name" />
            <label class="select-all-control">
              <input type="checkbox" id="selectAllCheckbox" class="select-all-checkbox" />
              <span id="selectAllLabel">Select</span>
            </label>
            <button type="button" class="toggle-all-btn" id="toggleAllBtn" title="Collapse/Expand all categories">
              <span id="toggleAllIcon">▼</span>
              <span id="toggleAllLabel">Collapse</span>
            </button>
            <button type="button" class="foss-toggle-btn" id="fossToggleBtn" title="Show only Free and Open Source Software">🌿 FOSS</button>
            <select id="optionsSelect" class="options-select">
              <option value="" hidden selected>⚙️ Options</option>
              <option value="loadFavorites">✨ My Favorites</option>
              <option value="importPackages">📥 Import Packages (JSON)</option>
              <option value="exportPackages">📤 Export Packages (JSON)</option>
            </select>
          </div>
          <input type="file" id="fileInput" accept=".json" style="display: none;" />
        </div>
      </div>
      <div id="packageContainer" class="package-container columns">
        <div class="loading-spinner" id="loadingSpinner">
          <div class="spinner"></div>
          <p>Loading packages...</p>
        </div>
      </div>
    </form>
  </section>
  <CommandFooter />
  <script>
    import '/src/scripts/app';
  </script>
</InstallerLayout>
