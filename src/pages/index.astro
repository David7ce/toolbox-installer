---
import BaseLayout from '../layouts/BaseLayout.astro';
const BASE = import.meta.env.BASE_URL;
---
<BaseLayout title="Toolbox Installer" extraStyles={['styles/generator.css', 'styles/home.css']}>
  <div class="page-wrapper home-page-wrapper">
    <header class="page-header home-header">
      <h1>Toolbox Installer</h1>
      <button type="button" id="themeToggle" class="theme-toggle" aria-label="Switch to dark mode" title="Dark mode">🌙</button>
    </header>
    <main class="home-main">
      <a href={`${BASE}desktop`} class="home-link home-link-desktop">Desktop OS</a>
      <a href={`${BASE}mobile`} class="home-link home-link-mobile">Mobile OS</a>
      <a href={`${BASE}vscode`} class="home-link home-link-vscode">VS Code Extensions</a>
      <a href={`${BASE}browser`} class="home-link home-link-browser">Browser Extensions</a>
      <a href={`${BASE}lib`} class="home-link home-link-lib">Libraries</a>
    </main>
  </div>
</BaseLayout>
