---
import InstallerLayout from '../layouts/InstallerLayout.astro';
import CommandFooter from '../components/CommandFooter.astro';
import PackageControls from '../components/PackageControls.astro';
---
<InstallerLayout
  title="Browser Extensions Installer"
  heading="Browser Extensions Installer"
  navBack={{ href: '/', label: 'Back to Home' }}
  navCompat={{ href: '/browser-extensions-compatibility', label: 'Go Browser Extensions Table' }}
>
  <section class="package-section">
    <div class="container">
      <PackageControls searchPlaceholder="Search by extension name" showFileInput={false}>
        <select id="browserSelect" class="options-select">
          <option value="both">🌐 Both browsers</option>
          <option value="firefox">🦊 Firefox</option>
          <option value="chromium">🔵 Chromium</option>
        </select>
        <select id="optionsSelect" class="options-select">
          <option value="" hidden selected>⚙️ Options</option>
          <option value="exportPackages">📤 Export Extensions (JSON)</option>
        </select>
      </PackageControls>
    </div>
    <div id="browserExtensionsCategories" class="package-container columns"></div>
  </section>
  <CommandFooter />
  <script>
    import '/src/scripts/packages-table';
  </script>
</InstallerLayout>
