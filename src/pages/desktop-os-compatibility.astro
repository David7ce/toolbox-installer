---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Package OS Compatibility" extraStyles={['/styles/os-compatibility.css']}>
  <div class="container">
    <header class="page-header">
      <h1>🖥️ Package OS Compatibility</h1>
      <button type="button" id="themeToggle" class="theme-toggle" aria-label="Switch to dark mode" title="Dark mode">🌙</button>
    </header>
    <p class="subtitle">Application availability across different operating systems.</p>
    <nav class="page-nav" aria-label="Page links">
      <div class="info-link">
        <a href="/index" title="Back to home page" aria-label="Back to home page">⬅ Back to Home</a>
      </div>
      <div class="info-link">
        <a href="/desktop" title="Go to installer" aria-label="Go to installer">⚙️ Go to Installer</a>
      </div>
    </nav>
    <div class="page-controls controls">
      <div class="page-controls-panel">
        <div class="search-box">
          <input type="search" id="searchInput" placeholder="Search package or category" />
        </div>
      </div>
      <div class="page-controls-panel">
        <div class="page-filter-row filter-chips" role="group" aria-label="Filter by OS availability">
          <button type="button" class="filter-chip active" data-os="all" aria-pressed="true">All</button>
          <button type="button" class="filter-chip" data-os="windows" aria-pressed="false">Windows</button>
          <button type="button" class="filter-chip" data-os="macos" aria-pressed="false">macOS</button>
          <button type="button" class="filter-chip" data-os="linux" aria-pressed="false">Linux</button>
          <button type="button" class="filter-chip" data-os="freebsd" aria-pressed="false">FreeBSD</button>
        </div>
      </div>
    </div>
    <div class="legend" aria-label="OS compatibility legend">
      <div class="legend-item"><span class="legend-icon">✅</span> Available (via package manager)</div>
      <div class="legend-item"><span class="legend-icon">⚠️</span> Available (manual installation)</div>
      <div class="legend-item"><span class="legend-icon">❌</span> Not available</div>
      <div class="legend-item legend-note">Linux includes: pacman + AUR, apt, rpm, emerge, flatpak, snap, nix</div>
    </div>
    <p class="page-note">Note: some vendor suites are not listed (Adobe, Autodesk, Apple, Microsoft).</p>
    <div class="table-container">
      <table id="packagesTable">
        <thead>
          <tr>
            <th class="sortable sticky-col category-col" data-column="category" tabindex="0" role="button" aria-sort="none">
              Category
              <span class="sort-arrows">
                <span class="sort-arrow up" data-column="category" data-direction="asc"></span>
                <span class="sort-arrow down" data-column="category" data-direction="desc"></span>
              </span>
            </th>
            <th class="sortable sticky-col app-col" data-column="name" tabindex="0" role="button" aria-sort="none">
              App
              <span class="sort-arrows">
                <span class="sort-arrow up" data-column="name" data-direction="asc"></span>
                <span class="sort-arrow down" data-column="name" data-direction="desc"></span>
              </span>
            </th>
            <th class="os-column">Win</th>
            <th class="os-column">Mac</th>
            <th class="os-column">Linux</th>
            <th class="os-column">FreeBSD</th>
          </tr>
        </thead>
        <tbody id="tableBody">
          <!-- Dynamically populated -->
        </tbody>
      </table>
    </div>
    <div class="stats">
      <div class="stat-item">
        <div class="stat-number" id="totalPackages">0</div>
        <div class="stat-label">Total Packages</div>
      </div>
      <div class="stat-item">
        <div class="stat-number" id="windowsCount">0</div>
        <div class="stat-label">Windows</div>
      </div>
      <div class="stat-item">
        <div class="stat-number" id="macosCount">0</div>
        <div class="stat-label">macOS</div>
      </div>
      <div class="stat-item">
        <div class="stat-number" id="linuxCount">0</div>
        <div class="stat-label">Linux</div>
      </div>
      <div class="stat-item">
        <div class="stat-number" id="freebsdCount">0</div>
        <div class="stat-label">FreeBSD</div>
      </div>
    </div>
  </div>
  <script>
    import '/src/scripts/os-compat-init';
  </script>
</BaseLayout>
