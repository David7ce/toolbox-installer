---
import BaseLayout from '../layouts/BaseLayout.astro';
const BASE = import.meta.env.BASE_URL;
---
<BaseLayout title="Browser Extensions Table" extraStyles={['styles/os-compatibility.css']}>
  <div class="container">
    <header class="page-header">
      <h1>🧩 Browser Extensions Compatibility</h1>
      <button type="button" id="themeToggle" class="theme-toggle" aria-label="Switch to dark mode" title="Dark mode">🌙</button>
    </header>
    <p class="subtitle">Extension list and store links for Firefox and Chromium-based browsers.</p>
    <nav class="page-nav" aria-label="Page links">
      <div class="info-link">
        <a href={BASE} title="Back to home page">⬅ Back to Home</a>
      </div>
      <div class="info-link">
        <a href={`${BASE}browser`} title="Go to installer">⚙️ Go to Installer</a>
      </div>
    </nav>
    <div class="page-controls controls">
      <div class="page-controls-panel">
        <div class="search-box">
          <input id="searchInput" type="search" placeholder="Search extension name, id, or category" />
        </div>
      </div>
      <div class="page-controls-panel">
        <div class="page-filter-row filter-chips" id="filterChips" role="group" aria-label="Filter by category"></div>
      </div>
    </div>
    <div class="table-container">
      <table id="packagesTable">
        <thead id="tableHead"></thead>
        <tbody id="tableBody"></tbody>
      </table>
    </div>
    <div class="stats" id="statsContainer"></div>
  </div>
  <script>
    import '/src/scripts/software-table-pages';
  </script>
</BaseLayout>
