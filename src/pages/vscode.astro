---
import InstallerLayout from '../layouts/InstallerLayout.astro';
import CommandFooter from '../components/CommandFooter.astro';
import PackageControls from '../components/PackageControls.astro';
---
<InstallerLayout
  title="VS Code Installer"
  heading="VS Code Installer"
  navBack={{ href: '/', label: 'Back to Home' }}
  navCompat={{ href: '/vscode-extensions-compatibility', label: 'Go VS Code Packages Table' }}
>
  <section class="package-section">
    <div class="container">
      <PackageControls searchPlaceholder="Search by extension name">
        <select id="optionsSelect" class="options-select">
          <option value="" hidden selected>⚙️ Options</option>
          <option value="loadFavorites">✨ My Favorites</option>
          <option value="importPackages">📥 Import Extensions (JSON)</option>
          <option value="exportPackages">📤 Export Extensions (JSON)</option>
        </select>
      </PackageControls>
    </div>
    <div id="extensionsCategories" class="package-container columns"></div>
  </section>
  <CommandFooter />
  <script>
    import '../scripts/packages-table';
  </script>
</InstallerLayout>
