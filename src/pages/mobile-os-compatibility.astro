---
import BaseLayout from '../layouts/BaseLayout.astro';
const BASE = import.meta.env.BASE_URL.replace(/\/?$/, '/');
---
<BaseLayout title="Mobile Packages Compatibility" extraStyles={['styles/os-compatibility.css']}>
  <div class="container">
    <header class="page-header">
      <h1>📱 Mobile Packages Compatibility</h1>
      <button type="button" id="themeToggle" class="theme-toggle" aria-label="Switch to dark mode" title="Dark mode">🌙</button>
    </header>
    <p class="subtitle">Complete package names and official store links for Android and iOS.</p>
    <nav class="page-nav" aria-label="Page links">
      <div class="info-link">
        <a href={BASE} title="Back to home page">⬅ Back to Home</a>
      </div>
      <div class="info-link">
        <a href={`${BASE}mobile`} title="Go to installer">⚙️ Go to Installer</a>
      </div>
    </nav>
    <div class="page-controls controls">
      <div class="page-controls-panel">
        <div class="search-box">
          <input type="search" id="searchInput" placeholder="Search package, category, or store ID" />
        </div>
      </div>
      <div class="page-controls-panel">
        <div class="page-filter-row filter-chips" id="filterChips" role="group" aria-label="Filter by mobile availability"></div>
      </div>
    </div>
    <p class="page-note">Search, sort, and filter mobile software by category and store availability.</p>
    <div class="table-container">
      <table id="packagesTable">
        <thead id="tableHead"></thead>
        <tbody id="tableBody"></tbody>
      </table>
    </div>
    <div class="stats" id="statsContainer"></div>
  </div>
  <script>
    import '/src/scripts/software-table-pages';
  </script>
</BaseLayout>
