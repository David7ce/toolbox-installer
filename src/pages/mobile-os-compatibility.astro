---
import CompatLayout from '../layouts/CompatLayout.astro';
---
<CompatLayout
  title="Mobile Packages Compatibility"
  heading="📱 Mobile Packages Compatibility"
  subtitle="Complete package names and official store links for Android and iOS."
  installerHref="mobile"
  installerLabel="Go to Installer"
  searchPlaceholder="Search package, category, or store ID"
>
  <div slot="controls" class="page-controls-panel">
    <div class="page-filter-row filter-chips" id="filterChips" role="group" aria-label="Filter by mobile availability"></div>
  </div>
  <p class="page-note">Search, sort, and filter mobile software by category and store availability.</p>
  <div class="table-container">
    <table id="packagesTable">
      <thead id="tableHead"></thead>
      <tbody id="tableBody"></tbody>
    </table>
  </div>
  <div class="stats" id="statsContainer"></div>
  <script slot="script">
    import '/src/scripts/software-table-pages';
  </script>
</CompatLayout>
