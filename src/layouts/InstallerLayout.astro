---
import BaseLayout from './BaseLayout.astro';
import PageHeader from '../components/PageHeader.astro';
import PageNav from '../components/PageNav.astro';

interface Props {
  title: string;
  heading: string;
  navBack?: { href: string; label: string };
  navCompat?: { href: string; label: string };
  extraStyles?: string[];
}

const { title, heading, navBack, navCompat, extraStyles = [] } = Astro.props;
---
<BaseLayout title={title} extraStyles={['/styles/generator.css', ...extraStyles]}>
  <div class="page-wrapper">
    <PageHeader heading={heading} />
    <PageNav backHref={navBack?.href} backLabel={navBack?.label} compatHref={navCompat?.href} compatLabel={navCompat?.label} />
    <slot />
  </div>
</BaseLayout>
